# Home Assistant Configuration
APP_HASS_HOST=http://homeassistant.local:8123
APP_HASS_TOKEN=your_long_lived_access_token_here

# Ollama Configuration (optional, for local AI)
# APP_OLLAMA_HOST=http://localhost:11434

# Application Configuration
APP_USE_LOCAL_API=true
# APP_APP_URL=http://localhost:3002

# Server Configuration
PORT=3002

# Traefik Configuration (optional)
# Labels for docker-compose with Traefik:
#   labels:
#     - "traefik.enable=true"
#     - "traefik.http.routers.lazyautomation.rule=Host(`lazyautomation.yourdomain.com`)"
#     - "traefik.http.routers.lazyautomation.tls=true"
#     - "traefik.http.routers.lazyautomation.entrypoints=websecure"
#     - "traefik.http.services.lazyautomation.loadbalancer.server.port=3000"
