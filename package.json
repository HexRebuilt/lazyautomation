    "docker:build": "docker build -t lazyautomation .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
